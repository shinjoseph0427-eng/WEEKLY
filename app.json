{
  "expo": {
    "name": "WEEKLY",
    "slug": "weekly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "weekly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.shinjoseph0427.weekly",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "WEEKLY uses your camera to add profile photos.",
        "NSPhotoLibraryUsageDescription": "WEEKLY lets you pick profile photos from your library.",
        "NSLocationWhenInUseUsageDescription": "WEEKLY uses your location to match you with people nearby this week.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.shinjoseph0427.weekly",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B00",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.143763314354-v9ihmpj8euasubjpgua0pu5uecik3t3j"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WEEKLY lets you pick profile photos from your library."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "WEEKLY matches you with people nearby this week."
        }
      ],
      "expo-image",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5a4ae734-88ef-400e-85ff-20b46340ad6b"
      }
    },
    "owner": "shinjoseph0427"
  }
}
