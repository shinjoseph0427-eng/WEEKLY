# WEEKLY app — public (EXPO_PUBLIC_*) env vars only. No service-role keys here.
# Copy to `.env` and fill in. All values below are PUBLIC client values.

# Supabase (same project as the web app) — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth client IDs (Google Cloud Console) — HUMAN-PROVIDED.
# webClientId is REQUIRED even on iOS: Supabase validates the id-token audience
# against it during signInWithIdToken. See HUMAN ACTION ITEMS in the build notes.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
